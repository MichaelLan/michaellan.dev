---
import TechIconRow from './TechIconRow.astro';

const links = [
  { href: '/blog/', label: 'Blog' },
  // { href: '/sobre-mi/', label: 'Sobre mí' },
  { href: '/uses/', label: 'Uses' },
  { href: 'https://github.com/michaellan', label: 'GitHub', external: true },
  { href: 'https://www.linkedin.com/in/michaellan/', label: 'LinkedIn', external: true },
];
---

<section class="hero container" aria-labelledby="hero-title">
  <div class="hero-copy">
    <h1 id="hero-title">Michael Lan</h1>
    <p class="hero-subtitle">Data engineer & software developer</p>
    <p class="hero-text">Construyo pipelines de datos, automatizo flujos complejos y exploro sistemas de inteligencia artificial aplicada.</p>
    <TechIconRow />
    <nav class="hero-links" aria-label="Enlaces principales">
      {links.map((link) => (
        <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noreferrer' : undefined}>{link.label}</a>
      ))}
    </nav>
  </div>
  <div class="portrait-wrap" aria-label="Diagrama técnico de pipeline de datos">
    <img src="/images/michael-lan.svg" alt="Diagrama abstracto de pipeline de datos con terminal, nodos y flujos" width="360" height="420" />
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(250px, 0.58fr);
    align-items: center;
    gap: clamp(var(--space-xl), var(--fluid-hero-gap), calc(var(--space-3xl) + var(--space-lg)));
  }

  .hero-copy {
    position: relative;
  }

  .hero-copy::before {
    position: absolute;
    top: -24px;
    left: 2px;
    width: 28px;
    height: 3px;
    border-radius: 999px;
    background: var(--color-accent-bright);
    box-shadow: 40px 0 0 rgb(56 189 248 / 72%), 74px 0 0 rgb(246 211 91 / 86%);
    content: "";
    opacity: 0.82;
  }

  h1 {
    margin: 0;
    font-size: clamp(var(--text-hero-title-min), var(--fluid-hero-title), var(--text-hero-title-max));
    font-weight: 700;
    line-height: var(--leading-hero);
    letter-spacing: var(--tracking-hero);
  }

  .hero-subtitle {
    width: max-content;
    max-width: 100%;
    margin: var(--space-sm) 0 0;
    color: var(--color-muted);
    font-size: clamp(var(--text-sm), var(--fluid-small-text), var(--text-base));
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .hero-text {
    max-width: 520px;
    margin: var(--space-md) 0 0;
    color: var(--color-muted);
    font-size: clamp(var(--text-body), var(--fluid-body-text), var(--text-2xs));
    line-height: var(--leading-body);
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-md);
    margin-top: var(--space-lg);
  }

  .hero-links a {
    position: relative;
    color: var(--color-muted);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    transition: color var(--transition), transform var(--transition);
  }

  .hero-links a:hover {
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  .hero-links a::after {
    position: absolute;
    right: 0;
    bottom: -4px;
    left: 0;
    height: 1px;
    content: "";
    background: linear-gradient(90deg, var(--color-accent), var(--color-cyan));
    opacity: 0.6;
    transform: scaleX(0.18);
    transform-origin: left;
    transition: transform var(--transition), opacity var(--transition);
  }

  .hero-links a:hover::after {
    transform: scaleX(1);
  }

  .portrait-wrap {
    position: relative;
    justify-self: end;
    width: min(100%, 320px);
  }

  .portrait-wrap::before,
  .portrait-wrap::after {
    position: absolute;
    content: "";
    pointer-events: none;
  }

  .portrait-wrap::before {
    inset: 18px -10px -10px 24px;
    border-right: 1px solid rgb(15 118 110 / 18%);
    border-bottom: 1px solid rgb(15 118 110 / 18%);
    border-radius: 22px;
  }

  .portrait-wrap::after {
    top: -14px;
    right: -14px;
    width: 46px;
    height: 46px;
    border-top: 1px solid var(--color-cyan);
    border-right: 1px solid var(--color-cyan);
    opacity: 0.72;
  }

  img {
    position: relative;
    z-index: 1;
    width: 100%;
    filter: drop-shadow(0 18px 30px rgb(17 21 19 / 8%));
  }

  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
      padding-top: var(--space-md);
    }

    .portrait-wrap {
      justify-self: start;
      width: min(64vw, 260px);
    }
  }

  @media (max-width: 520px) {
    h1 {
      font-size: clamp(var(--text-hero-title-mobile-min), var(--fluid-hero-title-mobile), var(--text-hero-title-mobile-max));
    }

    .hero-subtitle {
      width: auto;
      letter-spacing: normal;
    }
  }
</style>
