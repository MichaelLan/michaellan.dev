---
const navItems = [
  { href: '/blog/', label: 'Blog' },
  // { href: '/sobre-mi/', label: 'Sobre mí' },
  { href: '/uses/', label: 'Uses' },
];

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner container">
    <a class="brand" href="/" aria-label="Ir al inicio">ML.</a>
    <nav class="site-nav" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[{ active: pathname === item.href || pathname.startsWith(item.href) }]}
          aria-current={pathname === item.href || pathname.startsWith(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    padding: var(--space-lg) 0 var(--space-sm);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    min-height: 36px;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: var(--text-md);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    text-decoration: none;
    transition: color var(--transition), transform var(--transition);
  }

  .brand:hover {
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: clamp(var(--space-md), var(--fluid-nav-gap), var(--space-xl));
  }

  .site-nav a {
    position: relative;
    color: var(--color-muted);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    transition: color var(--transition);
  }

  .site-nav a::after {
    position: absolute;
    right: 0;
    bottom: -7px;
    left: 0;
    height: 1px;
    content: "";
    background: linear-gradient(90deg, var(--color-accent), var(--color-cyan));
    opacity: 0;
    transform: scaleX(0.42);
    transition: opacity var(--transition), transform var(--transition);
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--color-accent);
  }

  .site-nav a:hover::after,
  .site-nav a.active::after {
    opacity: 1;
    transform: scaleX(1);
  }

  @media (max-width: 520px) {
    .site-header {
      padding-top: var(--space-md);
    }

    .brand {
      min-width: 34px;
      min-height: 34px;
    }

    .site-nav {
      gap: var(--space-sm);
    }

    .site-nav a {
      font-size: var(--text-sm);
    }
  }
</style>
